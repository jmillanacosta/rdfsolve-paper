@InProceedings{emonet_sparqleditor,
author="Emonet, Vincent
and Sima, Ana-Claudia
and Mendes de Farias, Tarcisio",
editor="Curry, Edward
and Presutti, Valentina
and McCrae, John
and Alam, Mehwish
and Colpaert, Pieter
and Xavier Parreira, Josiane
and Collarana, Diego
and Sabou, Marta
and Harth, Andreas
and Lisena, Pasquale",
title="A User-Friendly SPARQL Query Editor Powered by Lightweight Metadata",
booktitle="The Semantic Web: ESWC 2025 Satellite Events",
year="2026",
publisher="Springer Nature Switzerland",
address="Cham",
pages="3--7",
abstract="SPARQL query editors often lack intuitive interfaces to aid SPARQL-savvy users to write queries. To address this issue, we propose an easy-to-deploy, triple store-agnostic and open-source query editor that offers three main features: (i) automatic query example rendering, (ii) precise autocomplete based on existing triple patterns including within SERVICE clauses, and (iii) a data-aware schema visualization. It can be easily set up with a custom HTML element. The tool has been successfully tested on various public endpoints, and is deployed online at https://sib-swiss.github.io/sparql-editorwith open-source code available at https://github.com/sib-swiss/sparql-editor.",
isbn="978-3-031-99554-5"
}

